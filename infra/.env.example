# Copy this to infra/.env and fill in real values before running deploy.sh
# infra/.env is gitignored — never commit real credentials

# New Relic
NR_LICENSE_KEY=your-40-char-license-key-here
NEW_RELIC_LICENSE_KEY=your-40-char-license-key-here
NEW_RELIC_APP_NAME=nr-sandbox

# Grafana Cloud OTLP
# Endpoint: Grafana Cloud → Home → Connections → OpenTelemetry
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp
# Auth: base64("<grafana-instance-id>:<grafana-api-token>")
# Generate with: echo -n "<id>:<token>" | base64
GRAFANA_OTLP_AUTH=base64-encoded-id-colon-token-here

# App config (defaults work as-is on EC2)
REDIS_URL=redis://localhost:6379
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=nr-sandbox
